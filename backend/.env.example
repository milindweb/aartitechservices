# Supabase Configuration - Environment Variables
# Copy this file to .env.local and fill in your actual values

# ============================================================
# SUPABASE PROJECT
# ============================================================

# Your Supabase Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase Anon/Public Key (safe to expose in frontend)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (KEEP PRIVATE - backend only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Database connection string (for migrations and seeds)
DATABASE_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres

# ============================================================
# AUTHENTICATION
# ============================================================

# Auth redirects
AUTH_REDIRECT_URL=https://mk9.in/auth/callback
AUTH_CONFIRM_URL=https://mk9.in/auth/confirm

# Session settings
SESSION_TIMEOUT_MINUTES=1440
REFRESH_TOKEN_ROTATION_ENABLED=true

# ============================================================
# EMAIL CONFIGURATION
# ============================================================

# Supabase Auth Email (uses built-in email by default)
SUPABASE_EMAIL_ENABLED=true

# Optional: Custom SMTP for email
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM_EMAIL=noreply@mk9.in
SMTP_FROM_NAME=MK9 Solutions

# ============================================================
# STORAGE CONFIGURATION
# ============================================================

# Storage bucket names
STORAGE_BUCKET_BLOG=blog
STORAGE_BUCKET_HOSPITAL=hospital
STORAGE_BUCKET_SOCIETY=society
STORAGE_BUCKET_SENIORITY=seniority
STORAGE_BUCKET_DOCUMENTS=documents
STORAGE_BUCKET_REPORTS=reports
STORAGE_BUCKET_TEMPLATES=templates

# Max upload sizes (in bytes)
MAX_FILE_SIZE_IMAGES=5242880          # 5MB for images
MAX_FILE_SIZE_DOCUMENTS=52428800      # 50MB for documents
MAX_FILE_SIZE_REPORTS=104857600       # 100MB for reports

# Allowed file types
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp,svg
ALLOWED_DOCUMENT_TYPES=pdf,doc,docx,xlsx,xls,txt
ALLOWED_REPORT_TYPES=pdf,xlsx,csv

# ============================================================
# EDGE FUNCTIONS
# ============================================================

# Edge function URLs
FUNCTION_BLOG_POSTS=https://[project-id].supabase.co/functions/v1/blog-posts
FUNCTION_BLOG_COMMENTS=https://[project-id].supabase.co/functions/v1/blog-comments
FUNCTION_HOSPITAL_APPOINTMENTS=https://[project-id].supabase.co/functions/v1/hospital-appointments
FUNCTION_HOSPITAL_DOCTORS=https://[project-id].supabase.co/functions/v1/hospital-doctors
FUNCTION_SOCIETY_POSTS=https://[project-id].supabase.co/functions/v1/society-posts
FUNCTION_SENIORITY_RECORDS=https://[project-id].supabase.co/functions/v1/seniority-records
FUNCTION_ADMIN_AUDIT=https://[project-id].supabase.co/functions/v1/admin-audit

# Edge function auth header
EDGE_FUNCTION_AUTH_HEADER=Authorization

# ============================================================
# API CONFIGURATION
# ============================================================

# API base URL
API_BASE_URL=https://api.mk9.in
API_VERSION=v1

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=15

# CORS settings
CORS_ALLOWED_ORIGINS=https://mk9.in,https://blog.mk9.in,https://admin.mk9.in,http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# ============================================================
# LOGGING & MONITORING
# ============================================================

# Environment
NODE_ENV=production

# Logging level
LOG_LEVEL=info

# Enable detailed logging
DEBUG_MODE=false

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_PROVIDER=google

# Error tracking
SENTRY_DSN=

# ============================================================
# SECURITY
# ============================================================

# JWT Configuration
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=7

# CSRF Protection
CSRF_TOKEN_ENABLED=true
CSRF_TOKEN_LENGTH=32

# Rate limiting
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_WINDOW_MINUTES=15

# Password requirements
MIN_PASSWORD_LENGTH=8
REQUIRE_SPECIAL_CHARS=true
REQUIRE_NUMBERS=true
REQUIRE_UPPERCASE=true

# ============================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================

# Payment Gateway (optional)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Cloud Storage (backup)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=mk9-backups

# Email Newsletter
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=

# Analytics
GOOGLE_ANALYTICS_ID=GA-...

# ============================================================
# DATABASE
# ============================================================

# Connection pooling
DB_POOL_MIN=2
DB_POOL_MAX=20

# Query timeout
DB_QUERY_TIMEOUT_MS=30000

# Backup schedule (cron format)
DB_BACKUP_SCHEDULE=0 2 * * *

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================

# Site metadata
SITE_NAME=MK9 Solutions
SITE_URL=https://mk9.in
SITE_DESCRIPTION=Comprehensive solutions for digital, medical, and community management

# Feature flags
FEATURE_BLOG_ENABLED=true
FEATURE_HOSPITAL_ENABLED=true
FEATURE_SOCIETY_ENABLED=true
FEATURE_SENIORITY_ENABLED=true
FEATURE_ADMIN_ENABLED=true

# ============================================================
# CACHE CONFIGURATION
# ============================================================

# Redis (optional for session/cache)
REDIS_URL=redis://localhost:6379

# Cache TTL (in seconds)
CACHE_TTL_SHORT=300          # 5 minutes
CACHE_TTL_MEDIUM=3600        # 1 hour
CACHE_TTL_LONG=86400         # 1 day

# ============================================================
# NOTES
# ============================================================

# 1. NEVER commit .env.local to version control
# 2. Add .env.local to .gitignore
# 3. Use .env.example as template and version control it
# 4. Rotate secrets periodically
# 5. Use different keys for dev/staging/production
# 6. Keep sensitive data in secure vault or CI/CD secrets
# 7. Review security quarterly
